# ── ZEN ASSETS Backend Environment Variables ──
# Copy this to .env and fill in your values

PORT=4000
NODE_ENV=production

# JWT - generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_TO_RANDOM_64_CHAR_STRING
JWT_EXPIRES_IN=7d

# Admin account (seeded on first run)
ADMIN_EMAIL=admin@zenassets.com
ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD
ADMIN_NAME=ZEN Admin

# Frontend URL (for CORS)
FRONTEND_URL=https://zen-assets.surge.sh

# Database path (relative to backend/)
DB_PATH=./data/zen_assets.db

# Rate limiting
LOGIN_RATE_LIMIT=10
LOGIN_RATE_WINDOW=15

# SMTP (Nodemailer)
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=465
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
EMAIL_FROM="ZEN ASSETS <no-reply@zenassets.tech>"

# Or Resend API
RESEND_API_KEY=your_resend_api_key
EMAIL_FROM="ZEN ASSETS <no-reply@zenassets.tech>"

# Security
SESSION_SECRET=your_strong_session_secret

# HTTPS & HSTS
ENFORCE_HTTPS=true
HSTS_MAX_AGE=31536000
HSTS_PRELOAD=true

# Password Policy
MIN_PASSWORD_LENGTH=12
REQUIRE_UPPERCASE=true
REQUIRE_LOWERCASE=true
REQUIRE_NUMBERS=true
REQUIRE_SPECIAL_CHARS=true
